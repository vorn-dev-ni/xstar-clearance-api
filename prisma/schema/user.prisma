// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  firstName String
  lastName  String
  role      UserRole  @default(OPERATION)
  department String?
  phone     String?
  isActive  Boolean   @default(true)
  avatarUrl String?   // profile avatar image
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  incomeRecords    IncomeRecord[]
  incomeReceived   IncomeRecord[]  @relation("IncomeReceivedBy")
  expenseRecords   ExpenseRecord[]
  invoices         Invoice[]
  auditLogs        AuditLog[]
  deposits         Deposit[]
  vendorPayments   VendorPayment[]
  journalEntries   JournalEntry[]
  financialReports FinancialReport[]
  assignedClearanceJobs ClearanceJob[] @relation("JobAssignedStaff")

  @@index([email])
  @@index([role])
}

enum UserRole {
  SUPER_ADMIN
  ACCOUNTING
  OWNER
  OPERATION
}

/// Grants a permission (\`${module}.${capability}\`) to a role. Rows present =
/// granted. SUPER_ADMIN is a hardcoded bypass and is never stored here.
model RolePermission {
  id         String   @id @default(cuid())
  role       UserRole
  permission String
  createdAt  DateTime @default(now())

  @@unique([role, permission])
  @@index([role])
}
