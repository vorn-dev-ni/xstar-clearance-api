// ============================================
// INVOICING
// ============================================

model Invoice {
  id            String    @id @default(cuid())
  invoiceNumber String    @unique // ST25-000028
  invoiceDate   DateTime
  dueDate       DateTime?

  // Parties
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  // Amounts
  subtotal    Decimal @db.Decimal(15, 2)
  taxRate     Decimal @default(10) @db.Decimal(5, 2) // VAT rate
  taxAmount   Decimal @db.Decimal(15, 2)
  totalAmount Decimal @db.Decimal(15, 2)
  paidAmount  Decimal @default(0) @db.Decimal(15, 2)
  balanceDue  Decimal @db.Decimal(15, 2)
  currency    String  @default("USD")

  // Details
  description String?
  notes      String?
  status     InvoiceStatus @default(DRAFT)

  // Tax invoice vs debit note (not under company title)
  invoiceType       InvoiceType @default(TAX_INVOICE)
  underCompanyTitle Boolean     @default(true)

  // Tax info
  taxIdNumber String? // VAT ID for invoice

  // Tracking
  issuedBy     String
  issuedByUser User     @relation(fields: [issuedBy], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  lineItems    InvoiceLineItem[]
  payments     Payment[]
  journalEntry JournalEntry[]

  @@index([invoiceNumber])
  @@index([customerId])
  @@index([invoiceDate])
  @@index([status])
}

model InvoiceLineItem {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  itemNumber  Int
  description String
  quantity    Decimal @db.Decimal(15, 4)
  unitPrice   Decimal @db.Decimal(15, 2)
  amount      Decimal @db.Decimal(15, 2)
  taxable     Boolean @default(true)
  notes       String?

  @@unique([invoiceId, itemNumber])
  @@index([invoiceId])
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum InvoiceType {
  TAX_INVOICE
  DEBIT_NOTE
}
