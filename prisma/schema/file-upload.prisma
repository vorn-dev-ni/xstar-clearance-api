// ============================================
// FILE UPLOADS (S3)
// ============================================

/// Metadata for a file stored in S3. Uploaded directly by the client via a
/// presigned URL; `entityType`/`entityId` link it to any record (Invoice,
/// Patent, ...). `uploadedBy` is a userId (kept as a plain string).
model FileUpload {
  id           String           @id @default(cuid())
  key          String           @unique // S3 object key
  bucket       String
  originalName String
  mimeType     String
  size         Int?
  entityType   String? // "Invoice", "Patent", ...
  entityId     String?
  documentType DocumentType? // shipping-document category (for ClearanceJob files)
  status       FileUploadStatus @default(PENDING)
  uploadedBy   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([uploadedBy])
}

enum FileUploadStatus {
  PENDING
  UPLOADED
}

enum DocumentType {
  COMMERCIAL_INVOICE
  PACKING_LIST
  BILL_OF_LADING
  AIR_WAYBILL
  CERTIFICATE_OF_ORIGIN
  IMPORT_PERMIT
  INSURANCE_CERTIFICATE
  CUSTOMS_DECLARATION
  // Customer-profile documents
  PATENT
  YEARLY_VAT_PAYMENT
  REPRESENTATIVE_IMAGE
  MOC_DOCUMENT
  OTHER
}
