// ============================================
// SUPPLIERS
// ============================================

model Supplier {
  id            String   @id @default(cuid())
  code          String   @unique
  nameEn        String
  nameKh        String?
  nameCn        String?
  taxId         String?  @unique
  address       String
  commune       String?
  district      String?
  province      String?
  country       String   @default("Cambodia")
  phone         String?
  email         String?
  contactPerson String?
  paymentTerms  String?
  bankAccount   String?
  bankName      String?
  isActive      Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  expenseRecords ExpenseRecord[]
  deposits       Deposit[]

  @@index([taxId])
  @@index([code])
}
