// ============================================
// SETTINGS & CONFIGURATION
// ============================================

model CompanySettings {
  id            String  @id @default(cuid())
  companyNameEn String
  companyNameKh String?
  companyNameCn String?

  vatId           String  @unique
  businessLicense String?
  taxId           String?

  address  String
  province String
  country  String

  phone   String?
  email   String?
  website String?

  currency        String @default("USD")
  fiscalYearStart Int    @default(1) // Month

  defaultVatRate      Decimal @default(10) @db.Decimal(5, 2)
  defaultPaymentTerms Int     @default(30) // days

  logo String? // URL or base64

  // Bank / payment details printed on invoice & debit-note PDFs.
  bankName          String?
  bankAccountName   String?
  bankAccountNumber String?
  swiftCode         String?
  chequePayableNote String?
  khrExchangeRate   Decimal @default(4100) @db.Decimal(10, 2) // KHR per 1 USD

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
