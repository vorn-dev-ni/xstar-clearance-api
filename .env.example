# Copy to .env.development (and .env.production) and fill in real values.
# The API selects the file by NODE_ENV at startup.

NODE_ENV=development
# 3333 keeps the API clear of the Next.js dev server on :3000.
PORT=3333

# PostgreSQL connection string. For Neon, use the pooled connection string and
# keep sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Allowed CORS origins: "*" for any, or a comma-separated list.
# The Next.js admin frontend runs on :3000.
CORS_ORIGIN=http://localhost:3000

# Secret used to sign JWT access tokens. Use a long random value in production.
JWT_SECRET=replace_with_a_long_random_secret
# Access-token lifetime (jsonwebtoken duration string).
JWT_EXPIRY=24h

# Bootstrap admin account created by `pnpm db:seed`.
SEED_ADMIN_EMAIL=admin@stlogistics.com
SEED_ADMIN_PASSWORD=ChangeMe123!

# AWS S3 — backs the presigned-URL file upload service. Use an IAM key scoped to
# s3:PutObject/GetObject/DeleteObject/HeadObject on the bucket only.
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=replace_with_iam_access_key_id
AWS_SECRET_ACCESS_KEY=replace_with_iam_secret_access_key
# Lifetime (seconds) of generated presigned URLs.
S3_PRESIGN_EXPIRY=900
